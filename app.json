{
  "expo": {
    "name": "gymHoop",
    "slug": "gymHoop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gymhoop.cr",
      "infoPlist": {
        "FirebaseAppDelegateProxyEnabled": false,
        "NSUserNotificationUsageDescription": "Usamos notificaciones para avisarte sobre tus clases y novedades de Hoop.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.gymhoop.cr",
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b13da6ed-faed-453f-ac0d-27115b4a5de9"
      }
    }
  }
}
